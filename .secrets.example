Twitch App: Name deiner App
Client-ID:     DEINE_CLIENT_ID
Client-Secret: DEIN_CLIENT_SECRET
Twitch-Channel: DEIN_TWITCH_CHANNELNAME
PUBG API Key: DEIN_PUBG_API_KEY

# Optional: Steam Web API für Now-Playing + Achievements
# Key holen: https://steamcommunity.com/dev/apikey
# Steam ID: deine 17-stellige steamID64 (Tools wie steamid.io)
# Voraussetzung: Profil + 'Game Details' auf Public
Steam API Key: DEIN_STEAM_API_KEY
Steam ID:      76561198XXXXXXXXX
# Optional: Sprache fuer Achievement-Namen + Beschreibungen.
# Default: english. Codes: english, german, french, spanish, italian,
# russian, polish, portuguese, brazilian, japanese, koreana, schinese,
# tchinese, thai, turkish, czech, danish, dutch, finnish, greek,
# hungarian, norwegian, romanian, swedish, ukrainian, vietnamese.
# Steam fallback'd auf english wenn das Spiel die Sprache nicht hat.
# Aenderung erfordert sync-all-achievements?force=1 fuer Re-Download.
Steam-Language: german

# Optional: FTP-Backup für tägliche DB-Snapshots
# (alle 4 Pflicht — sonst kein Upload, nur lokales Backup)
# FTP-Backup-Host:  ftp.example.com
# FTP-Backup-User:  username
# FTP-Backup-Pass:  password
# FTP-Backup-Path:  /pubg-backups/
# FTP-Backup-Port:  21
# FTP-Backup-TLS:   true
