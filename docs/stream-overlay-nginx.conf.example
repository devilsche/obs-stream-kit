# nginx Server-Block — ALLES unter stream-overlay.com (eine Domain, ein Login).
#
# Etappe 1 der Konsolidierung:
#   - Service 1 (app, :9000) ist das Hauptbackend: Dashboard, Login/OAuth, Admin,
#     Widgets, Tools, PUBG/Steam-API, statische Assets.
#   - Service 2 (overlay_app, :9001) liefert nur die Produktions-Overlays + Clip-API.
#   - Ein Login-Cookie, host-only auf stream-overlay.com (greift fuer beide via nginx).
#
# Voraussetzungen:
#   - DNS A/AAAA "stream-overlay.com" -> Server (vorhanden)
#   - Cert: /etc/letsencrypt/live/stream-overlay.com/  (vorhanden)
#   - Twitch Dev Console: Redirect-URI https://stream-overlay.com/app/oauth/callback
#   - Datei nach /etc/nginx/sites-available/stream-overlay.com, verlinken, nginx -t, reload.

server {
    listen 80;
    listen [::]:80;
    server_name stream-overlay.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;
    server_name stream-overlay.com;

    ssl_certificate     /etc/letsencrypt/live/stream-overlay.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/stream-overlay.com/privkey.pem;

    # Overlay-Auslieferung + Twitch-Clip-API -> Service 2 (:9001)
    location ~ ^/s/[^/]+/(overlays|assets|js)/ {
        proxy_pass         http://127.0.0.1:9001;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-For   $remote_addr;
        proxy_set_header   X-Forwarded-Host  $host;
    }
    location ~ ^/s/[^/]+/api/twitch/ {
        proxy_pass         http://127.0.0.1:9001;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-For   $remote_addr;
        proxy_set_header   X-Forwarded-Host  $host;
    }

    # Alles andere -> Service 1 (:9000): Dashboard, Login/OAuth, Admin, Widgets,
    # Tools, PUBG/Steam-API (/s/<tok>/api/pubg|steam), statische Assets.
    location / {
        proxy_pass         http://127.0.0.1:9000;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-For   $remote_addr;
        proxy_set_header   X-Forwarded-Host  $host;
    }
}
