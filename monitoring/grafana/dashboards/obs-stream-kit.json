{
  "uid": "obs-stream-kit",
  "title": "OBS Stream Kit",
  "tags": ["obs-stream-kit"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "tenant",
        "label": "Tenant",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(obs_matches_per_tenant, tenant)",
        "includeAll": true,
        "multi": true,
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Tenants",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_tenants_total", "refId": "A" } ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Matches",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_matches_total", "refId": "A" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Players",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_players_total", "refId": "A" } ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Clans",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_clans_total", "refId": "A" } ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DB Size",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_db_size_bytes", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Telemetry Events",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "sum(obs_telemetry_events_by_type)", "refId": "A" } ]
    },

    {
      "id": 10,
      "type": "bargauge",
      "title": "Matches per Tenant",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_matches_per_tenant{tenant=~\"$tenant\"}", "legendFormat": "tenant {{tenant}}", "refId": "A" } ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Telemetry Events by Type",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "topk(20, obs_telemetry_events_by_type)", "legendFormat": "{{event_type}}", "refId": "A" } ],
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    },

    {
      "id": 20,
      "type": "timeseries",
      "title": "DB Growth (total)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "obs_db_size_bytes", "legendFormat": "total", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "DB Growth per Table (Top 6)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [ { "expr": "topk(6, obs_db_table_size_bytes)", "legendFormat": "{{table}}", "refId": "A" } ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },

    {
      "id": 30,
      "type": "row",
      "title": "External API Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "API Latency Overall (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(obs_external_api_duration_ms_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(obs_external_api_duration_ms_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(obs_external_api_duration_ms_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "API Latency by Provider (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (provider, le) (rate(obs_external_api_duration_ms_bucket[5m])))", "legendFormat": "{{provider}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "PUBG API Latency by Endpoint (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (endpoint, le) (rate(obs_external_api_duration_ms_bucket{provider=\"pubg\"}[5m])))", "legendFormat": "{{endpoint}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Steam API Latency by Endpoint (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (endpoint, le) (rate(obs_external_api_duration_ms_bucket{provider=\"steam\"}[5m])))", "legendFormat": "{{endpoint}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "API Calls/min by Provider+Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "sum by (provider, status) (rate(obs_external_api_calls_total[5m])) * 60", "legendFormat": "{{provider}} {{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 36,
      "type": "timeseries",
      "title": "HTTP Request Latency p95 by Path",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (path, le) (rate(obs_http_request_duration_ms_bucket[5m])))", "legendFormat": "{{path}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    }
  ]
}
