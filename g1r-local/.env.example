# G1R Local Proxy — Konfiguration
# Diese Datei nach ".env" kopieren (im selben Ordner wie server.py) und ausfüllen.
# server.py liest sie beim Start automatisch. Echte Umgebungsvariablen haben Vorrang.

# Prod-Forwarding: schickt jeden Mod-Schnappschuss zusätzlich an die Prod-DB-API.
# Volle Token-URL aus dem Dashboard (URLs-Seite → Tab "Gothic 1" → Setup-Block).
# Leer lassen = reiner Lokal-Server (kein Forwarding).
G1R_INGEST_URL=

# Optional: Steam-Anzeigename fürs Widget (z.B. PEX_LuCKoR).
G1R_STEAM_NAME=

# Selten nötig — nur wenn der Mod woanders hinschreibt:
# G1R_STATE_FILE=C:\obs-g1r\g1r-state.json
